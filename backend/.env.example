# Server Configuration
PORT=5000
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
API_BASE_URL=http://localhost:5000

# Database Connection (SQLite for dev, PostgreSQL for prod)
# For SQLite: DATABASE_URL="file:./dev.db"
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
DATABASE_URL="file:./dev.db"

# --- Razorpay ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- PayPal ---
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# --- Zoom (OAuth Server-to-Server App) ---
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# --- Google Meet ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:5000/api/video/callback

# --- Cloud Storage (AWS S3 / Wasabi) ---
STORAGE_PROVIDER=local # local, aws, wasabi
STORAGE_BUCKET=your_bucket_name
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_ENDPOINT= # For Wasabi: https://s3.wasabisys.com

# --- Email Services ---
SENDGRID_API_KEY=your_sendgrid_key
STRIPE_SECRET_KEY=your_stripe_key

# --- Admin Portal Credentials ---
ADMIN_EMAIL=admin@rootsastro.com
ADMIN_PASSWORD=secure_admin_password

